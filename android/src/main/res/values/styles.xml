<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- Show a splash screen on the activity. Automatically removed when
             Flutter draws its first frame -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    
    <!-- Bottom sheet text styles from design -->
    <style name="answer_call">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#A1A1AA</item>
    </style>

    <style name="put_1_222_3">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FAFAFA</item>
    </style>

    <style name="end_call_wi">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FAFAFA</item>
    </style>

    <style name="decline_inc">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#A1A1AA</item>
    </style>

    <!-- Theme for incoming call activity - shows over lock screen -->
    <style name="Theme.IncomingCall" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowActionBar">false</item>
        <!-- For showing over lock screen -->
    <!-- windowShowWhenLocked and windowTurnScreenOn are API 27+. Keep them in values-v27 only. -->
    </style>

    <!-- Theme for call-waiting bottom sheet overlay.
         MUST be truly translucent so it appears as an overlay on top of whatever
         is below (Flutter app, home screen, etc.) with NO visible screen transition.
         Unlike Theme.IncomingCall which needs windowIsTranslucent=false for lock-screen. -->
    <style name="Theme.CallWaitingSheet" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
