<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/incoming_call_background">

    <!-- Incoming call background: custom layered gradients matching spec -->
    <!-- Use a single drawable that composes the top bar, left/right gradients and central spotlight -->
    <!-- Replaces previous ellipse/vignette layering to precisely match design colors and blends -->
    <!-- Note: keep a subtle translucent bottom rect for action area via the background drawable itself -->
    <!-- Set the FrameLayout background to the new incoming background drawable -->
    
    <!-- Background drawable applied to root FrameLayout via android:background (set above) -->

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <!-- Top Section: Easify Logo with Name (Center Top) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="60dp">

            <!-- Easify Logo with Text (Center, larger) -->
            <ImageView
                android:id="@+id/easifyLogo"
                android:layout_width="90dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_easify_logo_with_name"
                android:contentDescription="Easify Logo"
                android:scaleType="fitCenter" />

        </LinearLayout>

    <!-- Spacer - increased spacing between logo and caller info to match reference -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.12" />

    <!-- Caller Information Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.15"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- "Call from" Label -->
        <TextView
            android:id="@+id/callFromLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call from"
            android:textSize="14sp"
            android:textColor="#D4D4D8"
            android:gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <!-- Caller Name -->
        <TextView
            android:id="@+id/callerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center_horizontal" />

        <!-- Caller Details (Mobile + Number) -->
        <TextView
            android:id="@+id/callerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile"
            android:textSize="16sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center_horizontal"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Spacer (Minimized between caller info and avatar) -->
    <!-- <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.001" /> -->

    <!-- Avatar Section with Animated Ring and Initials/Icon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.48"
        android:gravity="center">

        <!-- Center area intentionally left empty (no avatar, no ring, no initials) per design request -->

    </FrameLayout>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.01" />

    <!-- Action Buttons Section -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.20"
        android:orientation="horizontal"
        android:gravity="center_horizontal|center_vertical"
        android:layout_marginBottom="70dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Accept Button (Left) - solid green circle with white icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="70dp">

            <FrameLayout
                android:id="@+id/acceptButton"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/button_accept_ripple">

                <ImageView
                    android:id="@+id/acceptButtonCircle"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone_answer"
                    android:contentDescription="Accept Call"
                    android:scaleType="fitCenter"
                    android:tint="#FFFFFF" />

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:id="@+id/acceptButtonBg"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Decline Button (Right) - solid red circle with white icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="70dp">

            <FrameLayout
                android:id="@+id/declineButton"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/button_decline_ripple">

                <ImageView
                    android:id="@+id/declineButtonCircle"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone_end"
                    android:contentDescription="Decline Call"
                    android:scaleType="fitCenter"
                    android:tint="#FFFFFF" />

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:id="@+id/declineButtonBg"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    </LinearLayout>

    <!-- ============================== -->
    <!-- CALL WAITING BOTTOM SHEET      -->
    <!-- ============================== -->

    <!-- Blurred overlay (initially hidden) - captures & blurs background -->
    <ImageView
        android:id="@+id/callWaitingBottomSheetOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bottom Sheet Container (initially hidden) -->
    <LinearLayout
        android:id="@+id/callWaitingBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp"
        android:visibility="gone"
        android:elevation="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <!-- Drag Handle Indicator -->
        <!-- Drag handle removed per design: sheet should look like a card -->

        <!-- Heading: "Answer call and" (use grey style) -->
        <TextView
            android:id="@+id/answer_call"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/answer_call"
            android:textAppearance="@style/answer_call"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="4dp" />

        <!-- Option 1: Put on hold -->
        <LinearLayout
            android:id="@+id/optionHoldAndAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/icon_circle_yellow_ring">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_call_hold"
                    android:tint="#FFC107"
                    android:contentDescription="Hold" />

            </FrameLayout>

            <TextView
                android:id="@+id/put_1_222_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/put_1_222_3"
                android:textAppearance="@style/put_1_222_3"
                android:gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:ellipsize="end"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Option 2: End first call and answer -->
        <LinearLayout
            android:id="@+id/optionEndAndAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/icon_circle_red_filled">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_phone_end"
                        android:tint="#FFFFFF"
                        android:contentDescription="End Call" />

                </FrameLayout>

            <TextView
                android:id="@+id/end_call_wi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/end_call_wi"
                android:textAppearance="@style/end_call_wi"
                android:gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:ellipsize="end"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Option 3: Decline incoming call -->
        <LinearLayout
            android:id="@+id/optionDecline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/icon_circle_grey_outline">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_phone_decline_simple"
                        android:tint="#B0B0B0"
                        android:contentDescription="Decline" />

                </FrameLayout>

            <TextView
                android:id="@+id/decline_inc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/decline_inc"
                android:textAppearance="@style/decline_inc"
                android:gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:ellipsize="end"
                android:maxLines="2" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
