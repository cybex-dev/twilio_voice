<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/call_background">

    <!-- Background Pattern Image -->
    <ImageView
        android:id="@+id/backgroundPattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    android:src="@drawable/doodle_10_percentage"
        android:scaleType="centerCrop" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <!-- Top Section: Easify Logo with Name (Center Top) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.08"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="30dp">

            <!-- Easify Logo with Text (Center, larger) -->
            <ImageView
                android:id="@+id/easifyLogo"
                android:layout_width="90dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_easify_logo_with_name"
                android:contentDescription="Easify Logo"
                android:scaleType="fitCenter" />

        </LinearLayout>

    <!-- Spacer - Reduced spacing between logo and caller info -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.01" />

    <!-- Caller Information Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.15"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- "Call from" Label -->
        <TextView
            android:id="@+id/callFromLabel"
            android:layout_width="wrap_content"
            android:layout_height="21dp"
            android:text="Call from"
            android:textSize="14sp"
            android:textColor="#D4D4D8"
            android:gravity="center_horizontal|top" />

        <!-- Caller Name -->
        <TextView
            android:id="@+id/callerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:gravity="center_horizontal" />

        <!-- Caller Details (Mobile + Number) -->
        <TextView
            android:id="@+id/callerNumber"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:text="Mobile"
            android:textSize="16sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center_horizontal|top"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Spacer (Minimized between caller info and avatar) -->
    <!-- <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.001" /> -->

    <!-- Avatar Section with Animated Ring and Initials/Icon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.48"
        android:gravity="center">

        <!-- Blue Glow Effect Inside Ring -->
        <View
            android:id="@+id/avatarGlow"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:background="@drawable/avatar_glow" />

        <!-- Avatar Container with Animated Ring -->
        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="158dp"
            android:layout_height="158dp"
            android:layout_gravity="center" />

        <!-- Caller Initials/Person Icon (Center of ring) -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/avatar_center_background">

            <!-- Caller Initials (Initially Hidden, shown if name is known) -->
            <TextView
                android:id="@+id/callerInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="BT"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:visibility="visible" />

            <!-- Person Icon (Shown if name is unknown) -->
            <ImageView
                android:id="@+id/personIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person"
                android:scaleType="fitCenter"
                android:padding="20dp"
                android:contentDescription="Unknown Caller"
                android:visibility="gone" />

        </FrameLayout>

    </FrameLayout>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.01" />

    <!-- Action Buttons Section -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.20"
        android:orientation="horizontal"
        android:gravity="center_horizontal|center_vertical"
        android:layout_marginBottom="20dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Accept Button (Left) - with swipe gesture -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="70dp">

            <FrameLayout
                android:id="@+id/acceptButton"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/button_gray_ripple">

                <ImageView
                    android:id="@+id/acceptButtonCircle"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone_answer"
                    android:contentDescription="Accept Call"
                    android:scaleType="fitCenter"
                    android:tint="@color/button_accept_icon" />

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:id="@+id/acceptButtonBg"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Decline Button (Right) - with swipe gesture -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="70dp">

            <FrameLayout
                android:id="@+id/declineButton"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/button_gray_ripple">

                <ImageView
                    android:id="@+id/declineButtonCircle"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone_end"
                    android:contentDescription="Decline Call"
                    android:scaleType="fitCenter"
                    android:tint="@color/button_decline_icon" />

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:id="@+id/declineButtonBg"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    </LinearLayout>

    <!-- ============================== -->
    <!-- CALL WAITING BOTTOM SHEET      -->
    <!-- ============================== -->

    <!-- Dark overlay (initially hidden) -->
    <View
        android:id="@+id/callWaitingBottomSheetOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bottom Sheet Container (initially hidden) -->
    <LinearLayout
        android:id="@+id/callWaitingBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp"
        android:visibility="gone"
        android:elevation="16dp">

        <!-- Drag Handle Indicator -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bottom_sheet_handle" />

        <!-- Heading: "Answer call and" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Answer call and..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="4dp" />

        <!-- Option 1: Put on hold -->
        <LinearLayout
            android:id="@+id/optionHoldAndAnswer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_pause_circle"
                android:tint="#FFC107"
                android:contentDescription="Hold" />

            <TextView
                android:id="@+id/optionHoldText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Put caller on hold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="14dp" />

        </LinearLayout>

        <!-- Option 2: End first call and answer -->
        <LinearLayout
            android:id="@+id/optionEndAndAnswer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone_end"
                android:tint="#FF5252"
                android:contentDescription="End Call" />

            <TextView
                android:id="@+id/optionEndText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End call with caller"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="14dp" />

        </LinearLayout>

        <!-- Option 3: Decline incoming call -->
        <LinearLayout
            android:id="@+id/optionDecline"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bottom_sheet_option_ripple"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone_decline_simple"
                android:tint="#B0B0B0"
                android:contentDescription="Decline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline incoming call"
                android:textSize="16sp"
                android:textColor="#B0B0B0"
                android:layout_marginStart="14dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
